# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/dbname
SNOWFLAKE_DSN=snowflake://user:password@account/database
BQ_PROJECT=your-gcp-project-id

# LLM
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEFAULT_MODEL=gpt-4o
FALLBACK_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_S=1.0

# Pipeline config
E2E_TIMEOUT_S=45
CONTEXT_TOP_K_TABLES=5
CORRECTION_TOP_K=3
CORRECTION_MIN_SIMILARITY=0.85
MAX_TOKENS_PER_CALL=4096
SEMANTIC_LAYER_CACHE_TTL_S=3600
EMBEDDING_MODEL=all-MiniLM-L6-v2
PREVIEW_DEFAULT_LIMIT=100
JOIN_CONFIDENCE_EXECUTION_THRESHOLD=0.85

# Observability
LOG_LEVEL=INFO